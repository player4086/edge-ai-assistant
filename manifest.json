{
  "manifest_version": 3,
  "name": "AI 网页助手",
  "version": "1.0",
  "description": "AI 驱动的网页内容翻译、代码解释与高亮标记工具",
  "permissions": [
    "sidePanel",
    "storage",
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.deepseek.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "AI 网页助手"
  }
}
